---
title: Playbooks
description: Step-by-step guides for building real automations with OpenClaw. Copy, tweak, deploy.
permalink: /playbooks/
---
{% extends "base.njk" %}

{% block styles %}
  .page-header { padding: 64px 0 44px; text-align: center; }
  .page-header-pre { font-size: 0.78rem; font-weight: 600; color: var(--accent); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 14px; }
  .page-header h1 { font-family: 'Fraunces', serif; font-size: clamp(2.2rem, 5vw, 3rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.05; margin-bottom: 14px; color: var(--ink); }
  .page-header h1 em { font-style: italic; color: var(--accent); font-weight: 500; }
  .page-header p { font-size: 1.05rem; color: var(--ink-soft); max-width: 520px; margin: 0 auto; line-height: 1.6; }

  .cards { display: grid; grid-template-columns: 1fr; gap: 14px; padding-bottom: 80px; max-width: 760px; margin: 0 auto; }
  .card { display: block; padding: 24px 26px; border-radius: 14px; border: 1px solid var(--rule); background: var(--paper); text-decoration: none; color: inherit; transition: all 0.2s; }
  .card:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 12px 30px rgba(21, 36, 61, 0.07); }
  .card-title { font-family: 'Fraunces', serif; font-size: 1.2rem; font-weight: 600; margin-bottom: 6px; letter-spacing: -0.01em; color: var(--ink); line-height: 1.3; }
  .card-desc { font-size: 0.92rem; color: var(--ink-soft); line-height: 1.6; margin-bottom: 14px; }
  .card-meta { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
  .card-badge { font-size: 0.72rem; padding: 4px 10px; border-radius: 100px; background: var(--warm); color: var(--ink-soft); font-weight: 500; }
  .card-date { font-size: 0.78rem; color: var(--ink-mute); }

  .empty { text-align: center; padding: 60px 20px; border: 1px dashed var(--rule-strong); border-radius: 16px; background: var(--paper); color: var(--ink-mute); }
{% endblock %}

{% block body %}
  <div class="container-wide">
    <div class="page-header">
      <div class="page-header-pre">Playbooks</div>
      <h1>What owners are <em>actually building</em></h1>
      <p>Step-by-step playbooks from real operators using OpenClaw. Copy, tweak, deploy.</p>
    </div>
    <div class="cards">
      {% set items = collections.playbooks %}
      {% if items.length %}
        {% for post in items %}
        <a href="{{ post.url }}" class="card">
          <div class="card-title">{{ post.data.title }}</div>
          {% if post.data.description %}<div class="card-desc">{{ post.data.description }}</div>{% endif %}
          <div class="card-meta">
            <span class="card-date">{{ post.date | readableDate }}</span>
            {% if post.data.difficulty %}<span class="card-badge">{{ post.data.difficulty }}</span>{% endif %}
            {% if post.data.cost %}<span class="card-badge">{{ post.data.cost }}</span>{% endif %}
            {% if post.data.timeToSetup %}<span class="card-badge">{{ post.data.timeToSetup }}</span>{% endif %}
          </div>
        </a>
        {% endfor %}
      {% else %}
        <div class="empty">
          <p>Playbooks coming soon. 🛠️</p>
        </div>
      {% endif %}
    </div>
  </div>
{% endblock %}
