---
title: "404 — Page not found"
permalink: /404.html
---
{% extends "base.njk" %}

{% block styles %}
  .four-oh-four {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    text-align: center;
    padding: 2rem;
  }
  .four-oh-four .claw-ascii {
    font-family: 'JetBrains Mono', monospace;
    font-size: clamp(0.6rem, 1.2vw, 0.9rem);
    line-height: 1.2;
    color: var(--accent);
    opacity: 0.5;
    white-space: pre;
    margin-bottom: 2rem;
  }
  .four-oh-four h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(4rem, 12vw, 8rem);
    font-weight: 700;
    color: var(--ink);
    line-height: 1;
    margin-bottom: 0.5rem;
    letter-spacing: -0.04em;
  }
  .four-oh-four .subtitle {
    font-family: 'Fraunces', serif;
    font-size: 1.4rem;
    color: var(--ink);
    margin-bottom: 1rem;
    font-weight: 500;
  }
  .four-oh-four .quip {
    font-size: 1rem;
    color: var(--ink-soft);
    max-width: 460px;
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }
  .four-oh-four .home-btn {
    display: inline-block;
    padding: 13px 28px;
    background: var(--accent);
    color: white;
    text-decoration: none;
    border-radius: 100px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s;
  }
  .four-oh-four .home-btn:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
    color: white;
  }
  .four-oh-four .alt-links {
    margin-top: 1.5rem;
    font-size: 0.88rem;
    color: var(--ink-mute);
  }
  .four-oh-four .alt-links a {
    color: var(--accent);
    text-decoration: none;
    margin: 0 0.5rem;
  }
  .four-oh-four .alt-links a:hover { color: var(--accent-hover); text-decoration: underline; }
{% endblock %}

{% block body %}
<div class="four-oh-four">
  <div class="claw-ascii">
╔══════════════════════════════════╗
║                                  ║
║   &gt; searching for page...        ║
║   &gt; ...                          ║
║   &gt; nope. the claw came up empty ║
║   &gt; 🪝                           ║
║                                  ║
╚══════════════════════════════════╝
  </div>
  <h1>404</h1>
  <p class="subtitle">This page got automated out of existence.</p>
  <p class="quip">
    You either followed a broken link, typed something creative in the URL bar,
    or one of our agents deleted it while "optimizing."
    <br><br>
    We've dispatched a sub-agent to investigate. ETA: never.
  </p>
  <a href="/" class="home-btn">Back to the drop →</a>
  <div class="alt-links">
    or check out <a href="/playbooks/">Playbooks</a> · <a href="/learn/">Learn</a>
  </div>
</div>
{% endblock %}
