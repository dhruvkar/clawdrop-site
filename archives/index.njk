---
title: Newsletter Archives
description: Past issues of ClawDrop newsletter.
permalink: /archives/
---
{% extends "base.njk" %}

{% block styles %}
  .page-header { padding: 64px 0 44px; text-align: center; }
  .page-header-pre { font-size: 0.78rem; font-weight: 600; color: var(--accent); letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 14px; }
  .page-header h1 { font-family: 'Fraunces', serif; font-size: clamp(2.2rem, 5vw, 3rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.05; margin-bottom: 14px; color: var(--ink); }
  .page-header h1 em { font-style: italic; color: var(--accent); font-weight: 500; }
  .page-header p { font-size: 1.05rem; color: var(--ink-soft); max-width: 520px; margin: 0 auto; line-height: 1.6; }

  .cards { display: grid; grid-template-columns: 1fr; gap: 14px; padding-bottom: 80px; max-width: 760px; margin: 0 auto; }
  .card { display: block; padding: 22px 26px; border-radius: 14px; border: 1px solid var(--rule); background: var(--paper); text-decoration: none; color: inherit; transition: all 0.2s; }
  .card:hover { border-color: var(--accent); transform: translateY(-2px); box-shadow: 0 12px 30px rgba(21, 36, 61, 0.07); }
  .card-top { display: flex; justify-content: space-between; align-items: baseline; gap: 12px; margin-bottom: 6px; }
  .card-title { font-family: 'Fraunces', serif; font-size: 1.15rem; font-weight: 600; letter-spacing: -0.01em; color: var(--ink); }
  .card-issue { font-size: 0.76rem; color: var(--accent); white-space: nowrap; font-weight: 600; }
  .card-subject { font-size: 0.92rem; color: var(--ink-soft); line-height: 1.55; margin-bottom: 8px; }
  .card-date { font-size: 0.78rem; color: var(--ink-mute); }

  .empty { text-align: center; padding: 60px 20px; border: 1px dashed var(--rule-strong); border-radius: 16px; background: var(--paper); color: var(--ink-mute); }
{% endblock %}

{% block body %}
  <div class="container-wide">
    <div class="page-header">
      <div class="page-header-pre">Archives</div>
      <h1>Newsletter <em>archives</em></h1>
      <p>Every past issue of ClawDrop. Catch up on what you missed.</p>
    </div>
    <div class="cards">
      {% set items = collections.archives %}
      {% if items.length %}
        {% for post in items %}
        <a href="{{ post.url }}" class="card">
          <div class="card-top">
            <div class="card-title">{{ post.data.title }}</div>
            {% if post.data.issueNumber %}<div class="card-issue">Issue #{{ post.data.issueNumber }}</div>{% endif %}
          </div>
          {% if post.data.subject %}<div class="card-subject">{{ post.data.subject }}</div>{% endif %}
          <div class="card-date">{{ post.date | readableDate }}</div>
        </a>
        {% endfor %}
      {% else %}
        <div class="empty">
          <p>Issues coming soon.</p>
        </div>
      {% endif %}
    </div>
  </div>
{% endblock %}
