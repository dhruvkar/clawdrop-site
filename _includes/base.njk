<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — ClawDrop</title>
  <meta name="description" content="{{ description or content | excerpt }}">
  <meta property="og:title" content="{{ title }} — ClawDrop">
  <meta property="og:description" content="{{ description or content | excerpt }}">
  <meta property="og:type" content="{% if tags and 'learn' in tags %}article{% else %}website{% endif %}">
  <meta property="og:url" content="https://clawdrop.org{{ permalink or page.url }}">
  <meta property="og:site_name" content="ClawDrop">
  <meta property="og:locale" content="en_US">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="{{ title }} — ClawDrop">
  <meta name="twitter:description" content="{{ description or content | excerpt }}">
  <link rel="canonical" href="https://clawdrop.org{{ permalink or page.url }}">
  <link rel="alternate" type="application/rss+xml" title="ClawDrop" href="https://clawdrop.org/feed.xml">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🪝</text></svg>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700;9..144,900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-TKRMLFFMRB"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-TKRMLFFMRB');
  </script>
  <style>
    :root {
      --bg: #fdfaf3;
      --paper: #ffffff;
      --ink: #15243d;
      --ink-soft: #4a5773;
      --ink-mute: #8b95a8;
      --rule: #ece5d4;
      --rule-strong: #d8d1bc;
      --accent: #d8552c;
      --accent-hover: #c04a24;
      --accent-soft: #fdebe2;
      --warm: #f5ecd7;
      --code-bg: #15243d;
      --code-text: #e8eef7;
      --code-accent: #ffb38a;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: var(--bg);
      color: var(--ink);
      min-height: 100vh;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    a { color: var(--accent); }
    a:hover { color: var(--accent-hover); }

    .container { max-width: 760px; margin: 0 auto; padding: 0 28px; }
    .container-wide { max-width: 1080px; margin: 0 auto; padding: 0 28px; }

    nav { padding: 22px 0; background: var(--bg); border-bottom: 1px solid var(--rule); }
    nav .container-wide { display: flex; align-items: center; justify-content: space-between; }
    .logo { font-family: 'Fraunces', serif; font-size: 1.5rem; font-weight: 700; letter-spacing: -0.02em; color: var(--ink); text-decoration: none; display: inline-flex; align-items: center; gap: 10px; }
    .logo:hover { color: var(--ink); }
    .logo-img { width: 32px; height: 32px; border-radius: 7px; display: block; flex-shrink: 0; }
    .nav-links { display: flex; gap: 24px; align-items: center; font-size: 0.9rem; }
    .nav-link { color: var(--ink-soft); text-decoration: none; font-weight: 500; transition: color 0.2s; }
    .nav-link:hover { color: var(--accent); }
    .nav-cta { display: inline-flex; align-items: center; gap: 6px; padding: 10px 20px; border-radius: 100px; font-size: 0.85rem; font-weight: 600; text-decoration: none; background: var(--ink); color: white; transition: all 0.2s; }
    .nav-cta:hover { background: var(--accent); color: white; }

    footer { padding: 40px 0; border-top: 1px solid var(--rule); margin-top: 40px; text-align: center; font-size: 0.85rem; color: var(--ink-mute); }
    footer a { color: var(--ink-soft); text-decoration: none; }
    footer a:hover { color: var(--accent); }

    @media (max-width: 600px) {
      nav { padding: 16px 0; }
      .nav-links { gap: 14px; font-size: 0.82rem; }
      .nav-cta { padding: 8px 14px; font-size: 0.78rem; }
      .logo { font-size: 1.25rem; }
    }

    {% block styles %}{% endblock %}
  </style>
  {% block head %}{% endblock %}
</head>
<body>
  <nav>
    <div class="container-wide">
      <a href="/" class="logo"><img src="/assets/clawdrop-logo.png" alt="ClawDrop" class="logo-img">ClawDrop</a>
      <div class="nav-links">
        <a href="/playbooks/" class="nav-link">Playbooks</a>
        <a href="/learn/" class="nav-link">Learn</a>
        <a href="/#about" class="nav-link">About</a>
        <a href="/#subscribe" class="nav-cta">Subscribe</a>
      </div>
    </div>
  </nav>

  {% block body %}{% endblock %}

  <footer>
    <div class="container-wide">
      <p>© 2026 ClawDrop · Practical AI for operators · <a href="/privacy/">Privacy</a></p>
      <p>A Wints LLC company</p>
    </div>
  </footer>
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", function(user) {
        if (!user) {
          window.netlifyIdentity.on("login", function() {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>
</body>
</html>
