{% extends "base.njk" %}

{% block styles %}
  .post { max-width: 720px; margin: 0 auto; padding: 56px 28px 80px; }
  .post-back { color: var(--accent); text-decoration: none; font-size: 0.85rem; font-weight: 600; display: inline-flex; align-items: center; gap: 4px; }
  .post-back:hover { color: var(--accent-hover); }
  .post-date { color: var(--ink-mute); font-size: 0.82rem; margin-top: 16px; }
  .issue-num { color: var(--accent); font-size: 0.82rem; font-weight: 600; }
  .post h1 { font-family: 'Fraunces', serif; font-size: clamp(1.9rem, 4.5vw, 2.6rem); font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; margin: 12px 0 16px; color: var(--ink); }
  .post-subject { font-family: 'Fraunces', serif; font-size: 1.15rem; color: var(--ink-soft); line-height: 1.55; margin-bottom: 36px; padding-bottom: 36px; border-bottom: 1px solid var(--rule); font-weight: 400; }

  .post-content h2 { font-family: 'Fraunces', serif; font-size: 1.5rem; font-weight: 600; margin-top: 44px; margin-bottom: 14px; letter-spacing: -0.015em; color: var(--ink); }
  .post-content h3 { font-family: 'Fraunces', serif; font-size: 1.2rem; font-weight: 600; margin-top: 32px; margin-bottom: 10px; color: var(--ink); }
  .post-content p { color: var(--ink); font-size: 1rem; line-height: 1.75; margin-bottom: 18px; }
  .post-content a { color: var(--accent); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 2px; }
  .post-content a:hover { color: var(--accent-hover); }
  .post-content ul, .post-content ol { color: var(--ink); font-size: 1rem; line-height: 1.75; margin-bottom: 18px; padding-left: 24px; }
  .post-content li { margin-bottom: 6px; }
  .post-content blockquote { border-left: 3px solid var(--accent); padding: 14px 22px; margin: 22px 0; background: var(--warm); border-radius: 0 8px 8px 0; color: var(--ink-soft); font-size: 1rem; line-height: 1.7; font-family: 'Fraunces', serif; font-style: italic; }

  .post-content code { background: var(--code-bg); padding: 2px 6px; border-radius: 4px; font-size: 0.88em; font-family: 'JetBrains Mono', monospace; color: var(--code-accent); }
  .post-content pre { background: var(--code-bg); border-radius: 10px; padding: 20px 22px; overflow-x: auto; margin: 22px 0; box-shadow: 0 4px 14px rgba(21, 36, 61, 0.08); }
  .post-content pre code { background: none; padding: 0; font-size: 0.86rem; color: var(--code-text); line-height: 1.7; }
  .post-content strong { color: var(--ink); font-weight: 700; }

  .post-footer { margin-top: 56px; padding-top: 36px; border-top: 1px solid var(--rule); text-align: center; }
  .post-footer p { color: var(--ink-soft); font-size: 0.95rem; margin-bottom: 18px; }
  .btn-cta { display: inline-flex; align-items: center; gap: 8px; background: var(--accent); color: white; padding: 13px 28px; border-radius: 100px; text-decoration: none; font-weight: 600; font-size: 0.95rem; transition: all 0.2s; }
  .btn-cta:hover { background: var(--accent-hover); transform: translateY(-1px); color: white; }
{% endblock %}

{% block body %}
  <article class="post">
    <a href="/archives/" class="post-back">← All archives</a>
    <div class="post-date">
      {{ date | readableDate }}
      {% if issueNumber %} · <span class="issue-num">Issue #{{ issueNumber }}</span>{% endif %}
    </div>
    <h1>{{ title }}</h1>
    {% if subject %}<p class="post-subject">{{ subject }}</p>{% endif %}
    <div class="post-content">
      {{ content | safe }}
    </div>
    <div class="post-footer">
      <p>Never miss an issue. Subscribe to ClawDrop.</p>
      <a href="/" class="btn-cta">Subscribe →</a>
    </div>
  </article>
{% endblock %}
