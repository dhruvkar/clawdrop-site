---
title: Blueprints
description: Step-by-step guides for building real automations with OpenClaw.
permalink: /blueprints/
---
{% extends "base.njk" %}

{% block styles %}
  .page-header { padding: 60px 0 40px; text-align: center; position: relative; z-index: 2; }
  .page-header-pre { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: var(--accent-bright); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 16px; }
  .page-header h1 { font-size: clamp(2rem, 5vw, 2.8rem); font-weight: 900; letter-spacing: -0.04em; line-height: 1.1; margin-bottom: 12px; }
  .page-header h1 .hl { background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .page-header p { font-size: 1rem; color: var(--text-muted); max-width: 480px; margin: 0 auto; line-height: 1.6; }
  .cards { display: grid; grid-template-columns: 1fr; gap: 16px; padding-bottom: 80px; position: relative; z-index: 2; }
  .card { display: block; padding: 24px; border-radius: 14px; border: 1px solid var(--border); background: var(--bg-card); text-decoration: none; color: var(--text); transition: all 0.25s ease; }
  .card:hover { border-color: var(--border-glow); background: var(--bg-card-hover); transform: translateY(-2px); box-shadow: 0 0 30px var(--accent-glow); }
  .card-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 6px; letter-spacing: -0.02em; }
  .card-desc { font-size: 0.88rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 12px; }
  .card-meta { display: flex; gap: 10px; flex-wrap: wrap; }
  .card-badge { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; padding: 4px 8px; border-radius: 6px; background: rgba(108,92,231,0.1); border: 1px solid var(--border); color: var(--accent-bright); }
  .card-date { font-size: 0.75rem; color: var(--text-dim); }
  .empty { text-align: center; padding: 60px 20px; border: 1px dashed var(--border); border-radius: 16px; background: var(--bg-card); color: var(--text-muted); }
{% endblock %}

{% block body %}
  <div class="container-wide">
    <div class="page-header">
      <div class="page-header-pre">// blueprints</div>
      <h1>Automation <span class="hl">Blueprints</span></h1>
      <p>Step-by-step guides for building real automations with OpenClaw. Copy, tweak, deploy.</p>
    </div>
    <div class="cards">
      {% set items = collections.blueprints %}
      {% if items.length %}
        {% for post in items %}
        <a href="{{ post.url }}" class="card">
          <div class="card-title">{{ post.data.title }}</div>
          {% if post.data.description %}<div class="card-desc">{{ post.data.description }}</div>{% endif %}
          <div class="card-meta">
            <span class="card-date">{{ post.date | readableDate }}</span>
            {% if post.data.difficulty %}<span class="card-badge">{{ post.data.difficulty }}</span>{% endif %}
            {% if post.data.cost %}<span class="card-badge">{{ post.data.cost }}</span>{% endif %}
            {% if post.data.timeToSetup %}<span class="card-badge">{{ post.data.timeToSetup }}</span>{% endif %}
          </div>
        </a>
        {% endfor %}
      {% else %}
        <div class="empty">
          <p>Blueprints coming soon. 🛠️</p>
        </div>
      {% endif %}
    </div>
  </div>
{% endblock %}
