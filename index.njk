            <span class="pill">social monitoring</span>
            <span class="pill">family bots</span>
            <span class="pill">dev ops</span>
        </div>

        <div class="features">
            <div class="feature">
                <div class="feature-icon">🔧</div>
                <div class="feature-text">
                    <h3>Real setups, not demos</h3>
                    <p>From people actually using it. With context.</p>
