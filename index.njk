---
title: "5 OpenClaw Builds Every Week"
description: "See what people are actually building with OpenClaw. 5 practical use cases, automations, and AI assistant patterns delivered weekly."
permalink: /
---
{% extends "base.njk" %}

{% block styles %}
    .orb-3 { width: 300px; height: 300px; background: var(--green); top: 50%; left: 60%; animation: float3 18s ease-in-out infinite; position: fixed; border-radius: 50%; filter: blur(120px); opacity: 0.12; pointer-events: none; z-index: 0; }
    @keyframes float3 { 0%, 100% { transform: translate(0, 0); } 50% { transform: translate(-40px, 50px); } }

    .hero { padding: 60px 0 24px; text-align: center; }
    .hero-pre { font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; color: var(--accent-bright); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px; display: flex; align-items: center; justify-content: center; gap: 10px; }
    .hero-pre .dot { width: 6px; height: 6px; background: var(--green); border-radius: 50%; animation: pulse 2s ease-in-out infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }

    h1 { font-size: clamp(2.5rem, 7vw, 4rem); font-weight: 900; line-height: 1.05; letter-spacing: -0.04em; margin-bottom: 24px; }
    h1 .highlight { background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

    .hero-sub { font-size: 1.15rem; color: var(--text-muted); line-height: 1.7; max-width: 520px; margin: 0 auto 16px; }
    .hero-sub strong { color: var(--text); font-weight: 600; }

    .pills { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin: 32px 0 40px; }
    .pill { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; padding: 6px 14px; border-radius: 100px; border: 1px solid var(--border); color: var(--text-muted); background: var(--bg-card); transition: all 0.3s ease; cursor: default; }
    .pill:hover { border-color: var(--accent); color: var(--accent-bright); background: var(--accent-glow); }

    .form-section { background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px; padding: 40px 32px; margin-bottom: 40px; position: relative; overflow: hidden; }
    .form-section::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px; background: var(--gradient); opacity: 0.5; }
    .form-header { text-align: center; margin-bottom: 24px; }
    .form-header h2 { font-size: 1.3rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 8px; }
    .form-header p { font-size: 0.9rem; color: var(--text-muted); }
    .form-embed { width: 100%; min-height: 380px; border: none; border-radius: 8px; background: transparent; }
    .form-iframe-wrap { height: 240px; overflow: hidden; border-radius: 12px; }
    .form-iframe-wrap iframe { height: 500px !important; width: 100% !important; border: none; }

    .features { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 60px; }
    .feature { display: flex; gap: 16px; padding: 20px; border-radius: 12px; border: 1px solid var(--border); background: var(--bg-card); transition: all 0.3s ease; }
    .feature:hover { border-color: var(--border-glow); background: var(--bg-card-hover); transform: translateY(-2px); }
    .feature-icon { font-size: 1.5rem; flex-shrink: 0; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; background: var(--accent-glow); border-radius: 10px; }
    .feature-text h3 { font-size: 0.95rem; font-weight: 600; margin-bottom: 4px; letter-spacing: -0.01em; }
    .feature-text p { font-size: 0.82rem; color: var(--text-muted); line-height: 1.5; }

    .past-drops { margin-bottom: 60px; }
    .past-drops-header { text-align: center; margin-bottom: 32px; }
    .past-drops-label { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px; }
    .past-drops-header h2 { font-size: 1.5rem; font-weight: 800; letter-spacing: -0.03em; }
    .issue-card { display: block; text-decoration: none; color: inherit; padding: 20px; border-radius: 12px; border: 1px solid var(--border); background: var(--bg-card); margin-bottom: 12px; transition: all 0.3s ease; }
    .issue-card:hover { border-color: var(--border-glow); background: var(--bg-card-hover); transform: translateY(-2px); }
    .issue-card-inner { display: flex; justify-content: space-between; align-items: center; }
    .issue-num { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--accent-bright); }
    .issue-title { font-size: 1rem; font-weight: 700; margin-top: 4px; }
    .issue-desc { font-size: 0.8rem; color: var(--text-muted); margin-top: 4px; }
    .issue-date { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--text-dim); }
    .archive-link { display: inline-flex; align-items: center; gap: 8px; padding: 12px 28px; border-radius: 10px; border: 1px solid var(--border); color: var(--text-muted); text-decoration: none; font-size: 0.85rem; font-weight: 600; transition: all 0.3s ease; }
    .archive-link:hover { border-color: var(--accent); color: var(--accent-bright); }

    iframe { color-scheme: dark; }

    @media (max-width: 600px) {
        .hero { padding: 50px 0 30px; }
        .form-section { padding: 28px 20px; }
        .pills { gap: 6px; }
        .pill { font-size: 0.65rem; padding: 5px 10px; }
        .features { grid-template-columns: 1fr; }
    }
{% endblock %}

{% block body %}
    <div class="orb orb-3"></div>

    <div class="container">
        <section class="hero">
            <div class="hero-pre">
                <span class="dot"></span>
                Tailored weekly from raw internet
