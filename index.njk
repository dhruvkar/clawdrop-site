            </div>
            <div class="feature">
                <div class="feature-icon">⚡</div>
                <div class="feature-text">
                    <h3>Steal-ready</h3>
                    <p>Enough detail to recreate every build.</p>
                </div>
            </div>
            <div class="feature">
                <div class="feature-icon">🧠</div>
