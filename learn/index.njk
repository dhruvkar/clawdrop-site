---
title: "Learn OpenClaw"
description: "Practical guides for getting the most out of OpenClaw. Cost breakdowns, best skills, use cases, and deep dives."
permalink: /learn/
---
{% extends "base.njk" %}

{% block styles %}
  .learn-hero { padding: 60px 0 40px; text-align: center; }
  .learn-hero h1 { font-size: clamp(2rem, 5vw, 2.8rem); font-weight: 900; letter-spacing: -0.03em; margin-bottom: 12px; }
  .learn-hero h1 .highlight { background: var(--gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .learn-hero p { font-size: 1.05rem; color: var(--text-muted); max-width: 520px; margin: 0 auto; line-height: 1.7; }
  .guides-grid { display: grid; gap: 16px; margin-bottom: 60px; }
  .guide-card { display: block; text-decoration: none; color: inherit; padding: 28px 24px; border-radius: 14px; border: 1px solid var(--border); background: var(--bg-card); transition: all 0.3s ease; }
  .guide-card:hover { border-color: var(--border-glow); background: var(--bg-card-hover); transform: translateY(-3px); }
  .guide-card-meta { font-family: 'JetBrains Mono', monospace; font-size: 0.72rem; color: var(--text-dim); margin-bottom: 10px; display: flex; gap: 12px; }
  .guide-card h2 { font-size: 1.15rem; font-weight: 700; letter-spacing: -0.02em; margin-bottom: 8px; }
  .guide-card p { font-size: 0.88rem; color: var(--text-muted); line-height: 1.6; }
{% endblock %}

{% block body %}
  <div class="container">
    <section class="learn-hero">
      <h1><span class="highlight">Learn</span> OpenClaw</h1>
      <p>Practical guides from people who use OpenClaw every day. No fluff, no theory. Just what works.</p>
    </section>

    <div class="guides-grid">
      {% for post in collections.learn %}
        <a href="{{ post.url }}" class="guide-card">
          <div class="guide-card-meta">
            {% if post.data.readTime %}<span>📖 {{ post.data.readTime }}</span>{% endif %}
            {% if post.data.lastUpdated %}<span>Updated {{ post.data.lastUpdated }}</span>{% endif %}
          </div>
          <h2>{{ post.data.title }}</h2>
          <p>{{ post.data.description }}</p>
        </a>
      {% endfor %}
    </div>
  </div>
{% endblock %}
